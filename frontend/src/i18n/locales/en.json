  "problem": {
    "label": "The Problem",
    "title": "A land system vulnerable to fraud",
    "items": [
      "Falsification of paper land titles",
      "Multiple sales of the same property",
      "Blocked successions and family conflicts",
      "Transaction opacity and corruption",
      "Administrative delays of several months"
    ]
  },
  "solution": {
    "label": "The Solution",
    "title": "SafeLand: trust through blockchain",
    "items": [
      "Unfalsifiable and traceable NFT land titles",
      "Atomic escrow with automatic DGI/ANCFCC tax split",
      "Fridda succession compliant with Islamic law (24 shares)",
      "Multi-sig Justice Override for disputes",
      "Instant and transparent transactions"
    ]
  },
  "features": {
    "label": "Architecture",
    "title": "5 Sovereign Smart Contracts",
    "subtitle": "A modular UUPS upgradeable architecture, compliant with OpenZeppelin v5 standards",
    "modules": {
      "nft": {
        "title": "SafeLandNFT",
        "subtitle": "ERC-721 — Land Titles",
        "desc": "Each land title is a unique NFT with IPFS metadata: type, area, geolocation, document hash. Secure transfers with multi-role verification (Agent, Notary, Justice)."
      },
      "registry": {
        "title": "SafeLandRegistry",
        "subtitle": "Central Index",
        "desc": "Global registry indexing all properties by city and owner. Real-time statistics: transactions, encumbrances, frauds prevented, judicial interventions."
      },
      "escrow": {
        "title": "SafeLandEscrow",
        "subtitle": "Atomic Fiscal Escrow",
        "desc": "Atomic real estate transactions with automatic tax split: 4% DGI + 1% ANCFCC + 95% seller. Sequencing: creation → seller signature → buyer deposit → notary validation."
      },
      "fridda": {
        "title": "SafeLandFridda",
        "subtitle": "ERC-1155 — Successions",
        "desc": "Succession engine compliant with Islamic law with 24 shares (fara'id). Automatic distribution, governance by heir proposals/votes, notarial finalization."
      },
      "justice": {
        "title": "SafeLandJustice",
        "subtitle": "Judicial Multi-Sig",
        "desc": "Ministry of Justice interventions: judicial freeze, burn & remint (Justice Override), social key recovery. Configurable M-of-N threshold."
      },
      "security": {
        "title": "Security",
        "subtitle": "UUPS + AccessControl + ReentrancyGuard",
        "desc": "Upgradeable contracts via UUPS proxy. Granular role-based access control (Admin, Agent, Notary, Judge, Conservator). Reentrancy protection on all critical functions."
      }
    }
  },
