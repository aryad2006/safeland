{
  "name": "safeland-morocco",
  "version": "1.0.0",
  "description": "Plateforme NFT de Sécurisation Foncière au Maroc (B2G) — Blockchain Souveraine",
  "private": true,
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "test:coverage": "npx hardhat coverage",
    "deploy:local": "npx hardhat run scripts/deploy.js --network localhost",
    "deploy:testnet": "npx hardhat run scripts/deploy.js --network sepolia",
    "node": "npx hardhat node",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "lint:sol": "npx solhint 'contracts/**/*.sol'",
    "clean": "npx hardhat clean"
  },
  "keywords": [
    "blockchain",
    "nft",
    "foncier",
    "morocco",
    "b2g",
    "land-registry"
  ],
  "author": "SafeLand Morocco",
  "license": "UNLICENSED",
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.1.0",
    "hardhat": "^2.22.0",
    "solhint": "^5.0.0",
    "solidity-coverage": "^0.8.17"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0",
    "dotenv": "^16.4.0",
    "ethers": "^6.13.0"
  }
}
