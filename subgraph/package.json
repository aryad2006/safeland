{
  "name": "safeland-subgraph",
  "version": "1.0.0",
  "description": "TheGraph subgraph for SafeLand — Moroccan land registry on blockchain",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "deploy": "graph deploy --node https://api.studio.thegraph.com/deploy/ safeland-subgraph",
    "create-local": "graph create --node http://localhost:8020/ safeland-subgraph",
    "remove-local": "graph remove --node http://localhost:8020/ safeland-subgraph",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 safeland-subgraph"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "^0.71.0",
    "@graphprotocol/graph-ts": "^0.32.0"
  }
}
