# ─────────────────────────────────────────────────────────────────────
# SafeLand Morocco — Configuration d'environnement
# Copiez ce fichier : cp .env.example .env
# Ne commitez JAMAIS le fichier .env dans git
# ─────────────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────

# Port d'écoute du serveur Express (défaut: 3001)
PORT=3001

# URL du frontend autorisée pour CORS
FRONTEND_URL=http://localhost:3000

# Chemin vers la base de données SQLite (défaut: ./data/safeland.db)
DB_PATH=./data/safeland.db

# ── JWT ───────────────────────────────────────────────────────────────

# Clé secrète JWT — MUST être longue (>= 32 chars) et aléatoire en prod
# En dev, si absent, une clé aléatoire est générée au démarrage (non persistante)
# Générer : openssl rand -hex 64
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_openssl_rand_hex_64

# Durée de validité des tokens JWT (ex: 7d, 24h, 3600)
JWT_EXPIRES=7d

# ── Blockchain locale (Hardhat) ───────────────────────────────────────

# URL du nœud RPC (réseau local Hardhat)
RPC_URL=http://127.0.0.1:8545

# Clé privée du compte déployeur (Hardhat compte #0 — NE PAS utiliser en prod)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── Adresses des contrats (remplir après déploiement) ────────────────
# Les valeurs sont dans deployed-addresses.json après npx hardhat run scripts/deploy.js

NFT_ADDRESS=
REGISTRY_ADDRESS=
ESCROW_ADDRESS=
FRIDDA_ADDRESS=
JUSTICE_ADDRESS=
TIMELOCK_ADDRESS=

# ── Réseau Sepolia (testnet) ──────────────────────────────────────────

# URL RPC Sepolia (Infura / Alchemy)
# Ex: https://sepolia.infura.io/v3/YOUR_PROJECT_ID
SEPOLIA_RPC_URL=

# Clé API Etherscan pour la vérification des contrats
ETHERSCAN_API_KEY=

# ── IPFS / Pinata ────────────────────────────────────────────────────

# Clés API Pinata pour l'upload des métadonnées NFT
# https://app.pinata.cloud/keys
PINATA_API_KEY=
PINATA_API_SECRET=

# URL de la gateway IPFS pour lire les fichiers
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ── TheGraph (subgraph) ───────────────────────────────────────────────

# URL du subgraph déployé (The Graph Studio ou self-hosted)
# Ex: https://api.studio.thegraph.com/query/12345/safeland/version/latest
SUBGRAPH_URL=

# ── Frontend ──────────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_CHAIN_ID=31337

# ── Notes de sécurité ────────────────────────────────────────────────
# 1. Ne commitez jamais .env dans git (.gitignore inclut déjà .env)
# 2. En production, utilisez un gestionnaire de secrets (Vault, AWS SSM, etc.)
# 3. Rotez le JWT_SECRET régulièrement (invalide tous les tokens existants)
# 4. Le PRIVATE_KEY Hardhat (#0) est public — à remplacer impérativement en prod
